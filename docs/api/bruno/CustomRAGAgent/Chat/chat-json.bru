meta {
  name: Chat JSON
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/langgraph/threads/{{threadId}}/runs
  body: json
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "assistant_id": "mcp_agent_executor",
    "input": {
      "model": "{{defaultModel}}",
      "messages": [
        {
          "type": "human",
          "content": "What documents mention Oracle vector search?"
        }
      ],
      "session_id": "{{sessionId}}",
      "collection_name": "{{defaultCollection}}"
    }
  }
}
