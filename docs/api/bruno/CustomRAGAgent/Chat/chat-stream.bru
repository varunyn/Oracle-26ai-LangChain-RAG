meta {
  name: Chat Stream
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/api/langgraph/threads/{{threadId}}/runs/stream
  body: json
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "assistant_id": "mcp_agent_executor",
    "input": {
      "model": "{{defaultModel}}",
      "messages": [
        {
          "type": "human",
          "content": "Explain the current RAG workflow."
        }
      ],
      "session_id": "{{sessionId}}",
      "collection_name": "{{defaultCollection}}"
    }
  }
}
