            "anyOf": [
              {
                "type": "boolean"
              },
              {
                "type": "null"
              }
            ],
            "description": "Enable tracing",
            "title": "Enable Tracing"
          },
          "mcp_server_keys": {
            "anyOf": [
              {
                "items": {
                  "type": "string"
                },
                "type": "array"
              },
              {
                "type": "null"
              }
            ],
            "description": "MCP server keys from MCP_SERVERS_CONFIG to load tools",
            "title": "Mcp Server Keys"
          },
          "messages": {
            "description": "Conversation messages (OpenAI-compatible format)",
            "items": {
              "$ref": "#/components/schemas/ChatMessage"
            },
            "title": "Messages",
            "type": "array"
          },
          "mode": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "description": "Flow mode: rag | mcp | mixed | direct; default rag for backward compat",
            "title": "Mode"
          },
          "model": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "description": "Model ID",
            "title": "Model"
          },
          "session_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "description": "Browser/session ID for grouping traces (new per tab load or refresh)",
            "title": "Session Id"
          },
          "stream": {
            "default": false,
            "description": "If true, return SSE stream",
            "title": "Stream",
            "type": "boolean"
          },
          "thread_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "description": "Conversation thread ID for checkpointer memory",
            "title": "Thread Id"
          }
        },
        "required": [
          "messages"
        ],
        "title": "ChatCompletionsRequest",
        "type": "object"
      },
