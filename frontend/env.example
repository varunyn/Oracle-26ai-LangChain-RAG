# Optional server-side backend URL (used by Next server for config fetch)
FASTAPI_BACKEND_URL=http://localhost:3002

# Browser API base for direct frontend->backend calls (recommended for no /api proxy)
NEXT_PUBLIC_API_BASE=http://localhost:3002

# Default flow mode in the UI: rag | mcp | mixed | direct (optional; default is rag)
# NEXT_PUBLIC_DEFAULT_FLOW_MODE=direct
