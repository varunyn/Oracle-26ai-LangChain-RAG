# Custom RAG Agent environment configuration
# Copy this file to .env and set your real values there (.env is gitignored).
# Precedence: environment variables > .env > built-in defaults.
# See docs/CONFIGURATION.md for the full reference.

# General / OCI authentication
DEBUG=false
AUTH=API_KEY
OCI_PROFILE=CHICAGO
OCI_CONFIG_FILE=~/.oci/config
REGION=us-chicago-1
COMPARTMENT_ID=ocid1.compartment.oc1..your-compartment-ocid
# Optional; computed from REGION if unset.
# SERVICE_ENDPOINT=

# LLM configuration
LLM_MODEL_ID=meta.llama-3.3-70b-instruct
TEMPERATURE=0.1
MAX_TOKENS=4000
# Optional model picker list; comma-separated or JSON array (single line).
# If unset, defaults are derived from REGION.
# MODEL_LIST=google.gemini-2.5-pro,meta.llama-4-scout-17b-16e-instruct,meta.llama-4-maverick-17b-128e-instruct-fp8,xai.grok-code-fast-1,xai.grok-4-1-fast-non-reasoning,xai.grok-4-1-fast-reasoning
# Optional UI labels for models; JSON object (single line).
# MODEL_DISPLAY_NAMES={"google.gemini-2.5-pro":"Gemini 2.5 Pro","meta.llama-4-scout-17b-16e-instruct":"Llama 4 Scout 17B","meta.llama-4-maverick-17b-128e-instruct-fp8":"Llama 4 Maverick 17B","xai.grok-code-fast-1":"Grok Code Fast 1","xai.grok-4-1-fast-non-reasoning":"Grok 4.1 Fast (non-reasoning)","xai.grok-4-1-fast-reasoning":"Grok 4.1 Fast (reasoning)"}

# Embeddings configuration
EMBED_MODEL_TYPE=OCI
EMBED_MODEL_ID=cohere.embed-v4.0

# Oracle Vector Store (required for RAG search)
VECTOR_DB_USER=your_user
VECTOR_DB_PWD=your_password
VECTOR_DSN=your_dsn
VECTOR_WALLET_DIR=/path/to/wallet
VECTOR_WALLET_PWD=wallet_password
# CONNECT_ARGS is optional and derived from VECTOR_* values if unset.
DB_TCP_CONNECT_TIMEOUT=5
DB_SEARCH_TIMEOUT_SEC=15
DB_SEARCH_MAX_WORKERS=4

# RAG / search configuration
TOP_K=6
RAG_SEARCH_MODE=vector
# COLLECTION_LIST can be comma-separated or a JSON array (for example: RAG_KNOWLEDGE_BASE or col1,col2).
COLLECTION_LIST=RAG_KNOWLEDGE_BASE
DEFAULT_COLLECTION=RAG_KNOWLEDGE_BASE
CHUNK_SIZE=4000
CHUNK_OVERLAP=100
MAX_MSGS_IN_HISTORY=6
ENABLE_RERANKER=true
RERANKER_MIN_DOCS=3
RERANKER_MAX_DOC_TOKENS=1024

# UI-facing backend options
ENABLE_USER_FEEDBACK=true

# Conversation memory / threads
# See docs/SERVER-OWNED-MEMORY.md when using these options.
# ENABLE_PERSISTENT_MEMORY=true
# LANGGRAPH_SQLITE_PATH=.local-data/langgraph-checkpoints.sqlite
# ALLOW_CLIENT_THREAD_ID=true
# THREAD_ID_STRATEGY=uuid4
# THREAD_ID_PREFIX=

# MCP client configuration
ENABLE_MCP_TOOLS=true
# Deprecated: ignored for mode selection; use MCP_SERVERS_CONFIG instead.
# MCP_SERVER_KEYS=default,context7
MCP_TOOL_SELECTION_MAX_TOOLS=5
# MCP_TOOL_SELECTION_ALWAYS_INCLUDE=[]
MCP_TOOL_SELECTION_TEMPERATURE=0
MCP_SEARCH_MODE=vector
ENABLE_MCP_CLIENT_JWT=false
# MCP_MAX_ROUNDS=2
# MCP_SERVERS_CONFIG must be a JSON object on a single line.
# See docs/MCP-USAGE.md for the full schema.
# Example when backend and MCP server both run on the host:
# MCP_SERVERS_CONFIG={"calculator":{"transport":"streamable-http","url":"http://localhost:9000/mcp"}}
# Example when backend runs in Docker and MCP server runs on the host:
# MCP_SERVERS_CONFIG={"calculator":{"transport":"streamable-http","url":"http://host.docker.internal:9000/mcp"}}
# If the backend runs locally and MCP_SERVERS_CONFIG contains host.docker.internal,
# it is auto-mapped to localhost.
# With ENABLE_MCP_TOOLS=true and a non-empty MCP_SERVERS_CONFIG, chat mode defaults
# to mixed unless the request mode overrides it.
# MCP_SERVER_KEYS and request mcp_server_keys are deprecated / ignored for mode selection.
# Supported transports: streamable_http and streamable-http are accepted;
# code mode may map them to http internally.
MCP_USE_ANONYMIZED_TELEMETRY=false
SCARF_NO_ANALYTICS=true
DO_NOT_TRACK=true
POSTHOG_DISABLED=true

# MCP server runtime (mcp_servers/*.py)
TRANSPORT=streamable-http
HOST=0.0.0.0
PORT=9000

# Observability / OTEL (optional)
# DOCKER_STACKS is optional; leave unset to auto-include stacks from the flags below.
# See docs/DOCKER-SETUP.md for details.
ENABLE_OTEL_TRACING=false
# OTEL_TRACES_ENDPOINT=
# OTEL_TRACES_HEADERS=
# OTEL_LOGS_ENDPOINT=
ENABLE_OBSERVABILITY_STACK=false
# OBSERVABILITY_STACK_SERVICES=["loki","tempo","otel-collector","grafana"]

# Langfuse tracing (optional)
ENABLE_LANGFUSE_TRACING=false
# Local runs use localhost. In Docker, compose may override this to http://langfuse-web:3000.
LANGFUSE_HOST=http://localhost:3300
LANGFUSE_PUBLIC_KEY=pk-lf-your-project-key
LANGFUSE_SECRET_KEY=sk-lf-your-secret-key
LANGFUSE_TRACING_ENVIRONMENT=development
# LANGFUSE_ENVIRONMENT=development
# LANGFUSE_RELEASE=
# LANGFUSE_TAGS=["rag-api"]
# LANGFUSE_DEFAULT_USER_ID=

# OCI Logging Analytics (optional)
# ENABLE_OCI_LOGGING_ANALYTICS=false
# LOGGING_ANALYTICS_NAMESPACE=
# LOGGING_ANALYTICS_LOG_GROUP_ID=
# LOGGING_ANALYTICS_LOG_SET=
# LOGGING_ANALYTICS_RESOURCE_CATEGORY=rag-api
# LOGGING_ANALYTICS_META_PROPERTIES=
